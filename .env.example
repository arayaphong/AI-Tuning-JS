# Google AI Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_AI_API_KEY=your-api-key

# MongoDB MCP Configuration
# Local MongoDB
MDB_MCP_CONNECTION_STRING=mongodb://localhost:27017/ai_tuning
# OR Atlas connection
# MDB_MCP_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/ai_tuning

# Optional: Atlas API credentials for cluster management
MDB_MCP_API_CLIENT_ID=your-atlas-service-account-client-id
MDB_MCP_API_CLIENT_SECRET=your-atlas-service-account-client-secret

# MongoDB Safety Settings
MDB_MCP_READ_ONLY=false
MDB_MCP_INDEX_CHECK=true
MDB_MCP_DISABLED_TOOLS=

# Application Settings
NODE_ENV=development
LOG_LEVEL=info
